# Configuração do app mobile CardioIA.
# Copie este arquivo para `.env` (que NÃO é versionado) e ajuste os valores.
#
# As variáveis precisam do prefixo EXPO_PUBLIC_ para serem expostas ao app.

# Modo de execução:
#   true  -> demonstração com dados simulados, sem backend (padrão)
#   false -> usa o backend Flask real
EXPO_PUBLIC_USE_MOCK=true

# Endereço do backend Flask (usado apenas quando USE_MOCK=false).
# Descubra o IP da máquina que roda o Flask:
#   Windows: ipconfig  -> "Endereço IPv4" do adaptador Wi-Fi
#   macOS:   ipconfig getifaddr en0
#   Linux:   hostname -I
# Celular e máquina precisam estar na MESMA rede Wi-Fi. Porta padrão do Flask: 5050.
EXPO_PUBLIC_API_URL=http://192.168.0.100:5050
